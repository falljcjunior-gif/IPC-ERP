# .gitleaksignore
# ══════════════════════════════════════════════════════════════
# Gitleaks — Faux positifs connus pour IPC-ERP
# ══════════════════════════════════════════════════════════════

# Clé Firebase publique (apiKey) — Conçue pour être publique, protégée par App Check + Firestore Rules
# Référence: https://firebase.google.com/docs/projects/api-keys
[firebase-app-apikey]
# src/firebase/config.js — firebase apiKey est publique par conception Firebase
path = "src/firebase/config.js"

# VAPID Key FCM — Clé publique de notification push, non secrète
[vapid-public-key]
path = "public/firebase-messaging-sw.js"

# Clés reCAPTCHA site key — Clé publique, conçue pour être dans le frontend
[recaptcha-site-key]
path = ".env"

# Fichiers de scratch/tests — Non déployés en production
[scratch-files]
path = "scratch/"

# Fichiers de bootstrap temporaires
[bootstrap-temp]
path = "functions/bootstrap_admin.cjs"
