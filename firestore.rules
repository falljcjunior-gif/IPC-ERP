rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ── FONCTIONS DE SÉCURITÉ CENTRALISÉES ───────────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isSuperAdmin() {
      return isAuthenticated() && getUserData().permissions.roles.hasAny(['SUPER_ADMIN']);
    }
    
    function hasAnyRole(roles) {
      return isSuperAdmin() || (isAuthenticated() && getUserData().permissions.roles.hasAny(roles));
    }

    // ── MODULES MÉTIER (STRICT RBAC) ─────────────────────────────────────────
    
    // FINANCE: Seul le rôle FINANCE ou ADMIN peut modifier
    match /finance_invoices/{docId} {
      allow read: if hasAnyRole(['FINANCE', 'ADMIN', 'SALES']);
      allow write: if hasAnyRole(['FINANCE', 'ADMIN']);
    }
    match /finance_accounting/{docId} {
      allow read: if hasAnyRole(['FINANCE', 'ADMIN']);
      allow write: if false; // Écritures réservées au système (Cloud Functions)
    }

    // INVENTORY & PRODUCTION
    match /inventory_products/{docId} {
      allow read: if isAuthenticated();
      allow write: if hasAnyRole(['STOCK_MANAGER', 'PRODUCTION_MANAGER', 'ADMIN']);
    }
    match /production_orders/{docId} {
      allow read: if hasAnyRole(['PRODUCTION_MANAGER', 'STOCK_MANAGER', 'ADMIN']);
      allow write: if hasAnyRole(['PRODUCTION_MANAGER', 'ADMIN']);
    }

    // CRM & SALES
    match /sales_leads/{docId} {
      allow read, write: if hasAnyRole(['SALES', 'MARKETING', 'ADMIN']);
    }

    // ── USERS & AUTH ────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || hasAnyRole(['ADMIN', 'HR']));
      allow write: if isSuperAdmin() || hasAnyRole(['ADMIN', 'HR']);
      allow update: if isAuthenticated() && request.auth.uid == userId && 
                    !request.resource.data.diff(resource.data).affectedKeys().hasAny(['permissions']);
    }

    // ── COMMUNICATIONS & SECOURISME (WebRTC) ──────────────────────────────────
    match /calls/{callId} {
      allow read, write: if isAuthenticated() && (
        resource == null || 
        resource.data.participants.hasAny([request.auth.uid])
      );
      match /offerCandidates/{candId} { allow read, write: if isAuthenticated() && get(/databases/$(database)/documents/calls/$(callId)).data.participants.hasAny([request.auth.uid]); }
      match /answerCandidates/{candId} { allow read, write: if isAuthenticated() && get(/databases/$(database)/documents/calls/$(callId)).data.participants.hasAny([request.auth.uid]); }
    }

    match /rooms/{roomId} {
      allow read, write: if isAuthenticated() && (resource == null || resource.data.members.hasAny([request.auth.uid]) || isSuperAdmin());
    }

    // ── AUDIT & SYSTEM (READ-ONLY FOR CLIENTS) ───────────────────────────────
    match /audit_logs/{docId} {
      allow read: if hasAnyRole(['ADMIN', 'FINANCE']);
      allow write: if false; // INTERDIT AU CLIENT - Réservé aux triggers Cloud
    }

    match /activities/{docId} {
      allow read: if hasAnyRole(['ADMIN', 'HR']);
      allow create: if isAuthenticated();
      allow update, delete: if false;
    }

    // Configuration et Workflows
    match /system_config/{docId} { allow read, write: if isSuperAdmin(); }
    match /workflows/{docId} { 
      allow read: if isAuthenticated(); 
      allow write: if isSuperAdmin(); 
    }
    
    match /notifications/{docId} {
      allow read, write: if isAuthenticated() && (
        resource == null || 
        resource.data.targetUserId == request.auth.uid ||
        isSuperAdmin()
      );
    }

    match /system_incidents/{docId} {
      allow read: if isSuperAdmin() || hasAnyRole(['ADMIN']);
      allow create: if isAuthenticated(); 
      allow update, delete: if false;
    }
  }
}
