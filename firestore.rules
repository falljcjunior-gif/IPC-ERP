rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {


    // [ROOT BYPASS] Only for verified SUPER_ADMIN via Custom Claims
    // This ensures administrative operations are secured at the protocol level.
    match /{document=**} {
      allow read, write: if request.auth != null && request.auth.token.role == 'SUPER_ADMIN';
    }

    // ── Helpers ──────────────────────────────────────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }

    // Custom Claims check (fastest — no Firestore read required)
    function hasClaimRole(roleName) {
      return isAuthenticated() && request.auth.token.get('role', '') == roleName;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasRole(roleName) {
      // 1. Check Custom Claims first (no Firestore read, instant)
      return hasClaimRole(roleName) ||
      // 2. Fallback to Firestore doc check
      (isAuthenticated() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && (
        getUserData().get('role', '') == roleName ||
        ('permissions' in getUserData() && 'roles' in getUserData().permissions && roleName in getUserData().permissions.roles)
      ));
    }

    function isCreatorEmail() {
      return isAuthenticated() && (
        request.auth.uid == 'Ii8G2Ad6GyUxaS63ecrzeaE6l883' || // gitleaks:allow nosemgrep
        request.auth.uid == 'li8G2Ad6GyUxaS63ecrzeaE6l883' || // gitleaks:allow nosemgrep
        request.auth.token.email == 'fall.jcjunior@gmail.com' || 
        request.auth.token.email == 'ra.yoman@ipcgreenblocks.com'
      );
    }

    function isSuperAdmin() {
      // Priority: Hardcoded UID → Custom Claims → Creator Email → Firestore doc
      return isCreatorEmail() || hasClaimRole('SUPER_ADMIN') || hasRole('SUPER_ADMIN');
    }

    function isAdmin() {
      return isSuperAdmin() || hasClaimRole('ADMIN') || hasRole('ADMIN');
    }

    function isManager() {
      return isAdmin() || hasClaimRole('MANAGER') || hasRole('MANAGER');
    }

    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    function isNotDeleted() {
      return !('_deletedAt' in resource.data) || resource.data._deletedAt == null;
    }

    // ── Users ─────────────────────────────────────────────────────────────────
    // Chaque utilisateur peut lire son propre profil. Les admins lisent tous.
    // Seuls les admins peuvent modifier les rôles.
    match /users/{userId} {
      allow read: if isAuthenticated() && (isOwner(userId) || isAdmin());
      allow create: if isAuthenticated() && (isAdmin() || isCreatorEmail());
      allow update: if isAuthenticated() && (
        (isOwner(userId) && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role'])) ||
        isAdmin()
      );
      allow delete: if isSuperAdmin();
    }

    // ── Employees (HR sub-collection alias) ───────────────────────────────────
    match /employees/{docId} {
      allow read: if isAuthenticated() && (isManager() || hasRole('HR') || isSuperAdmin());
      allow write: if isAuthenticated() && (isManager() || hasRole('HR') || isSuperAdmin());
      allow delete: if isSuperAdmin();
    }

    // ── Messages ─────────────────────────────────────────────────────────────
    // Lecture : tout utilisateur authentifié membre du room
    // Création : authentifié, avec son propre userId
    // Mise à jour : auteur (édition) ou tout le monde (readBy/reactions uniquement)
    // Suppression (soft) : auteur ou admin
    match /messages/{msgId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.keys().hasAll(['text', 'roomId', 'userId', 'userName']);
      allow update: if isAuthenticated() && (
        // Auteur peut modifier son message
        resource.data.userId == request.auth.uid ||
        // N'importe qui peut marquer comme lu ou ajouter une réaction
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['readBy', 'reactions', 'isDeleted', 'text']) ||
        isAdmin()
      );
      allow delete: if isAdmin();
    }

    // ── Rooms (salons de discussion) ──────────────────────────────────────────
    match /rooms/{roomId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAdmin();

      // Sous-collections room
      match /participants/{uid} {
        allow read, write: if isAuthenticated();
      }
      match /signals/{sigId} {
        allow read, write: if isAuthenticated();
      }
    }

    // ── Calls ─────────────────────────────────────────────────────────────────
    match /calls/{callId} {
      allow read: if isAuthenticated() && (
        resource.data.callerId == request.auth.uid ||
        resource.data.receiverId == request.auth.uid ||
        isAdmin()
      );
      allow create: if isAuthenticated() && request.resource.data.callerId == request.auth.uid;
      allow update: if isAuthenticated() && (
        resource.data.callerId == request.auth.uid ||
        resource.data.receiverId == request.auth.uid
      );
      allow delete: if isAuthenticated();
    }

    // ── Notifications ─────────────────────────────────────────────────────────
    match /notifications/{notifId} {
      allow read: if isAuthenticated() && (
        !('targetUserId' in resource.data) ||
        resource.data.targetUserId == null ||
        resource.data.targetUserId == request.auth.uid ||
        isAdmin()
      );
      allow create: if isAuthenticated(); // Workflow engine crée des notifs
      allow update: if isAuthenticated() && (
        resource.data.targetUserId == request.auth.uid ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['readBy']) ||
        isAdmin()
      );
      allow delete: if isAdmin();
    }

    // ── Workflows (BPM) ───────────────────────────────────────────────────────
    match /workflows/{wfId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && isManager();
    }

    // ── Modules Métier ────────────────────────────────────────────────────────
    // Règle par défaut : authentifié peut lire/écrire dans son périmètre
    // Les suppressions sont réservées aux managers/admins (soft-delete préféré)

    match /hr/{docId} {
      allow read: if isAuthenticated() && (
        isSuperAdmin() || isManager() || hasRole('HR') || 
        resource.data.userId == request.auth.uid
      );
      allow create: if isAuthenticated() && (isSuperAdmin() || isManager() || hasRole('HR'));
      allow update: if isAuthenticated() && (isSuperAdmin() || isManager() || hasRole('HR'));
      allow delete: if isSuperAdmin() || isManager();
    }

    match /finance/{docId} {
      allow read: if isAuthenticated() && (isManager() || hasRole('FINANCE') || hasRole('ACCOUNTING'));
      allow create, update: if isAuthenticated() && (isManager() || hasRole('FINANCE') || hasRole('ACCOUNTING'));
      allow delete: if false; // Hard-delete disabled. Use soft-delete (update _deletedAt).
    }

    match /accounting/{docId} {
      allow read: if isAuthenticated() && (isManager() || hasRole('FINANCE') || hasRole('ACCOUNTING'));
      allow create, update: if isAuthenticated() && (isManager() || hasRole('FINANCE') || hasRole('ACCOUNTING'));
      allow delete: if false;
    }

    match /sales/{docId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated() && (isManager() || hasRole('SALES') || hasRole('STAFF'));
      allow delete: if false;
    }

    match /crm/{docId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated() && (isManager() || hasRole('SALES') || hasRole('CRM'));
      allow delete: if false;
    }

    match /inventory/{docId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated() && (isManager() || hasRole('LOGISTICS') || hasRole('PRODUCTION'));
      allow delete: if false;
    }

    match /production/{docId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated() && (isManager() || hasRole('PRODUCTION'));
      allow delete: if false;
    }

    match /purchase/{docId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated() && (isManager() || hasRole('LOGISTICS') || hasRole('PURCHASE'));
      allow delete: if false;
    }

    match /logistics/{docId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated() && (isManager() || hasRole('LOGISTICS'));
      allow delete: if false;
    }

    match /legal/{docId} {
      allow read: if isAuthenticated() && (isManager() || hasRole('LEGAL'));
      allow create, update: if isAuthenticated() && (isManager() || hasRole('LEGAL'));
      allow delete: if false;
    }

    match /signature/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
      allow delete: if isAdmin();
    }

    match /base/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
      allow delete: if isAdmin();
    }

    match /activities/{docId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (
        resource.data._createdBy == request.auth.uid || isAdmin()
      );
      allow delete: if isAdmin();
    }

    match /marketing/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && (isManager() || hasRole('MARKETING'));
      allow delete: if isManager();
    }

    // ── Audit Trail (lecture seule pour tous, écriture Cloud Functions) ────────
    match /audit_logs/{logId} {
      allow read: if isAuthenticated() && (isAdmin() || hasRole('AUDIT') || hasRole('SECURITY'));
      allow write: if false; // Écrit uniquement par Cloud Functions (admin SDK)
    }

    // ── DMS / Documents ───────────────────────────────────────────────────────
    match /documents/{docId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated();
      allow delete: if false;
    }

    // ── Services Généraux / Administration ────────────────────────────────────
    match /mail_logs/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
      allow delete: if isAdmin();
    }
    match /office_supplies/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
      allow delete: if isAdmin();
    }
    match /visitors_log/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
      allow delete: if isAdmin();
    }
    match /facilities_tickets/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
      allow delete: if isAdmin();
    }

    // ── Paramètres Globaux (Hub de Configuration) ──────────────────────────────
    match /settings/{docId} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin(); // Uniquement pour le Super Admin
    }

    // ── Maintenance (GMAO) ──────────────────────────────────────────────────
    match /maintenance/{docId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated() && (isManager() || hasRole('PRODUCTION') || hasRole('MAINTENANCE'));
      allow delete: if false;
    }

    // ── Paie & Social ──────────────────────────────────────────────────────
    match /payroll/{docId} {
      allow read: if isAuthenticated() && (isManager() || hasRole('HR') || hasRole('FINANCE'));
      allow create, update: if isAuthenticated() && (isManager() || hasRole('HR') || hasRole('FINANCE'));
      allow delete: if false;
    }

    // ── Appels d'Offres (Procurement) ──────────────────────────────────────
    match /procurement/{docId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated() && (isManager() || hasRole('PURCHASE') || hasRole('FINANCE'));
      allow delete: if false;
    }

    // ── ESG & Environnement ────────────────────────────────────────────────
    match /esg/{docId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated() && (isManager() || hasRole('PRODUCTION'));
      allow delete: if false;
    }

    // ── Projets ────────────────────────────────────────────────────────────
    match /projects/{docId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated() && (isManager() || hasRole('STAFF'));
      allow delete: if false;
    }

    // ── Budget ─────────────────────────────────────────────────────────────
    match /budget/{docId} {
      allow read: if isAuthenticated() && (isManager() || hasRole('FINANCE'));
      allow create, update: if isAuthenticated() && (isManager() || hasRole('FINANCE'));
      allow delete: if false;
    }

    // ── Internal Infrastructure (Sync & Integrity) ──────────────────────────
    match /sync_queue/{docId} {
      allow read, write: if isSuperAdmin();
    }
    match /processedEvents/{docId} {
      allow read, write: if isSuperAdmin();
    }

    // ── Communication Hub (Mail Integration) ──────────────────────────────────
    match /user_mail_accounts/{userId} {
      allow read, write: if isOwner(userId) || isSuperAdmin();
    }
    match /user_mails/{mailId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isSuperAdmin());
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && (resource.data.userId == request.auth.uid || isSuperAdmin());
      allow delete: if isSuperAdmin();
    }
    match /mail_outbox/{docId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isSuperAdmin());
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSuperAdmin();
    }

    // ── Refus par défaut (sécurité) ────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
