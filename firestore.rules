rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function hasRole(role) {
      return request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.permissions.roles.hasAny([role]);
    }
    
    match /users/{userId} {
      allow read, write: if request.auth != null && (
        request.auth.uid == userId || 
        request.auth.token.email == 'ra.yoman@ipcgreenblocks.com'
      );
      allow read, write: if request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.permissions.roles.hasAny(['SUPER_ADMIN']);
    }
    
    match /system_config/{docId} {
      allow read, write: if request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.permissions.roles.hasAny(['SUPER_ADMIN']);
    }
    
    match /calls/{callId} {
      allow read, write: if request.auth != null;
      match /offerCandidates/{candId} {
        allow read, write: if request.auth != null;
      }
      match /answerCandidates/{candId} {
        allow read, write: if request.auth != null;
      }
    }

    match /{collectionName}/{docId} {
      allow read, write: if request.auth != null && (
        collectionName == 'crm' || 
        collectionName == 'sales' || 
        collectionName == 'inventory' || 
        collectionName == 'accounting' || 
        collectionName == 'projects' || 
        collectionName == 'audit_logs' || 
        collectionName == 'messages' ||
        collectionName == 'base' ||
        collectionName == 'workflows' ||
        collectionName == 'hr'
      );
    }
  }
}
