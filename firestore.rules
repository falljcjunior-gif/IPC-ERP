rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ⚠️  [PRODUCTION RULES — Debug wildcard removed]
    // All access is governed by the per-collection rules below.
    // SUPER_ADMIN bypass is handled at the collection level only.

    function isAuthenticated() {
      return request.auth != null;
    }

    // [SECURITY] Creator email check removed — rely on Custom Claims only.
    // Hardcoded personal emails in rules are a security anti-pattern.
    function isCreatorEmail() {
      return false; // Désactivé — utiliser uniquement les Custom Claims
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // Custom Claims check (fastest — no Firestore read required)
    function hasClaimRole(roleName) {
      return isAuthenticated() && request.auth.token.get('role', '') == roleName;
    }


    function hasRole(roleName) {
      // 1. Check Custom Claims first (no Firestore read, instant)
      return hasClaimRole(roleName) ||
      // 2. Fallback to Firestore doc check
      (isAuthenticated() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && (
        getUserData().get('role', '') == roleName ||
        ('permissions' in getUserData() && 'roles' in getUserData().permissions && roleName in getUserData().permissions.roles)
      ));
    }


    function isSuperAdmin() {
      // Priority: Hardcoded UID → Custom Claims → Creator Email → Firestore doc
      return isCreatorEmail() || hasClaimRole('SUPER_ADMIN') || hasRole('SUPER_ADMIN');
    }

    function isAdmin() {
      // [3-SPACE] Les rôles HOLDING_* sont au-dessus de ADMIN — bypass complet
      return isSuperAdmin() || isHoldingLevel() || hasClaimRole('ADMIN') || hasRole('ADMIN');
    }

    function isManager() {
      return isAdmin() || hasClaimRole('MANAGER') || hasRole('MANAGER');
    }

    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }



    // ── Users & HR (Unified Model 2.0) ──────────────────────────────────────
    match /users/{userId} {
      // Profile is public for authenticated users (Directory/Annuaire)
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && (isAdmin() || isCreatorEmail());

      // Self-update: only allow writes on explicitly "personal" fields.
      // All HR, financial, role, and hierarchy fields are STRICTLY blocked
      // even if the user crafts a raw Firestore request.
      allow update: if isAuthenticated() && (
        (isOwner(userId) && !request.resource.data.diff(resource.data).affectedKeys().hasAny([
          // Identity & Access — set by admin/HR only
          'role', 'permissions', 'employeeId',
          // HR professional fields — set by HR module only
          'hr', 'poste', 'departement', 'contractType', 'hireDate',
          'managerUid', 'managerName',
          // Financial — private vault sub-collection only
          'salary', 'salaire', 'bankDetails',
          // Security audit trail — set by Cloud Functions only
          '_security'
        ])) ||
        isAdmin()
      );
      allow delete: if isSuperAdmin();

      // THE HR VAULT: Isolation of sensitive data (salary, SSN, IBAN)
      // Located as a sub-collection of the user for better grouping
      match /hr_private/{subDocId} {
        allow read: if isAuthenticated() && (
          isOwner(userId) || hasRole('HR_MANAGER') || hasRole('DIRECTOR') || isSuperAdmin()
        );
        allow write: if isAuthenticated() && (hasRole('HR_MANAGER') || hasRole('DIRECTOR') || isSuperAdmin());
      }
    }

    // [DEPRECATED] Root HR collection — will be removed after migration
    // [3-SPACE ISOLATION] Chaque entité ne voit que ses propres enregistrements RH.
    match /hr/{docId} {
      allow read: if isAuthenticated() && canReadOwnEntity(resource.data.entity_id) && (
        isSuperAdmin() || isManager() || hasRole('HR') ||
        resource.data.get('userId', '') == request.auth.uid ||
        resource.data.get('ownerId', '') == request.auth.uid
      );
      allow create, update, delete: if false;
    }

    // [DEPRECATED] Alias for HR — entity scoped
    match /employees/{docId} {
      allow read: if isAuthenticated() && canReadOwnEntity(resource.data.entity_id) &&
                  (isManager() || hasRole('HR') || isSuperAdmin());
      allow create, update, delete: if false;
    }

    // ── Messages ─────────────────────────────────────────────────────────────
    // [3-SPACE ISOLATION] Les messages sont scopés par entité (entity_id dans le doc).
    // HOLDING voit tous les messages de toutes les entités (supervision groupe).
    // Design : un room cross-entité (ex. intercompany) doit avoir entity_id = 'HOLDING' ou null.
    match /messages/{msgId} {
      allow read: if isAuthenticated() && canReadOwnEntity(resource.data.entity_id);
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid
        && canWriteOwnEntity(request.resource.data.entity_id)
        && request.resource.data.keys().hasAll(['text', 'roomId', 'userId', 'userName']);
      allow update: if isAuthenticated() && canWriteOwnEntity(resource.data.entity_id) && (
        // Auteur peut modifier son message
        resource.data.userId == request.auth.uid ||
        // N'importe qui peut marquer comme lu ou ajouter une réaction
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['readBy', 'reactions', 'isDeleted', 'text']) ||
        isAdmin()
      );
      allow delete: if isAdmin() && canWriteOwnEntity(resource.data.entity_id);
    }

    // ── Rooms (salons de discussion) ──────────────────────────────────────────
    // [3-SPACE ISOLATION] Les rooms sont scopées par entité.
    // Rooms intercompany : entity_id = 'HOLDING' ou null → visibles par tous.
    match /rooms/{roomId} {
      allow read: if isAuthenticated() && canReadOwnEntity(resource.data.entity_id);
      allow create: if isAuthenticated() && canWriteOwnEntity(request.resource.data.entity_id);
      allow update: if isAuthenticated() && canWriteOwnEntity(resource.data.entity_id);
      allow delete: if isAdmin() && canWriteOwnEntity(resource.data.entity_id);

      // Sous-collections room
      match /participants/{uid} {
        allow read, write: if isAuthenticated();
      }
      match /signals/{sigId} {
        allow read, write: if isAuthenticated();
      }
    }

    // ── Calls ─────────────────────────────────────────────────────────────────
    match /calls/{callId} {
      allow read: if isAuthenticated() && (
        resource.data.callerId == request.auth.uid ||
        resource.data.receiverId == request.auth.uid ||
        isAdmin()
      );
      allow create: if isAuthenticated() && request.resource.data.callerId == request.auth.uid;
      allow update: if isAuthenticated() && (
        resource.data.callerId == request.auth.uid ||
        resource.data.receiverId == request.auth.uid
      );
      allow delete: if isAuthenticated();
    }

    // ── Notifications ─────────────────────────────────────────────────────────
    match /notifications/{notifId} {
      allow read: if isAuthenticated() && (
        !('targetUserId' in resource.data) ||
        resource.data.targetUserId == null ||
        resource.data.targetUserId == request.auth.uid ||
        isAdmin()
      );
      allow create: if isAuthenticated(); // Workflow engine crée des notifs
      allow update: if isAuthenticated() && (
        resource.data.targetUserId == request.auth.uid ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['readBy']) ||
        isAdmin()
      );
      allow delete: if isAdmin();
    }

    // ── Workflows (BPM) ───────────────────────────────────────────────────────
    // [3-SPACE ISOLATION] Les workflows sont scopés par entité.
    // HOLDING voit tous les workflows (supervision des processus) — lecture seule.
    match /workflows/{wfId} {
      allow read: if isAuthenticated() && canReadOwnEntity(resource.data.entity_id);
      allow write: if isAuthenticated() && isManager() && canWriteOwnEntity(request.resource.data.entity_id);
    }

    // ── Modules Métier ────────────────────────────────────────────────────────
    // Règle par défaut : authentifié peut lire/écrire dans son périmètre
    // Les suppressions sont réservées aux managers/admins (soft-delete préféré)

    // ── HR Logic consolidated in /users/{userId} ─────────────────────────────


    match /helpdesk/{docId} {
      allow read: if isAuthenticated() && (
        (resource.data.categorie == 'Confidentiel RH' && (
           resource.data.demandeurId == request.auth.uid || hasRole('HR_MANAGER') || hasRole('HR')
        )) || 
        (resource.data.categorie != 'Confidentiel RH' && (
           resource.data.demandeurId == request.auth.uid || isSuperAdmin() || isManager() || hasRole('SUPPORT')
        ))
      );
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (
        (resource.data.categorie == 'Confidentiel RH' && (
           resource.data.demandeurId == request.auth.uid || hasRole('HR_MANAGER') || hasRole('HR')
        )) || 
        (resource.data.categorie != 'Confidentiel RH' && (
           isSuperAdmin() || isManager() || hasRole('SUPPORT') || resource.data.demandeurId == request.auth.uid
        ))
      );
      allow delete: if false;
    }

    // [3-SPACE ISOLATION] Tous ces business modules sont scopés par entity_id.
    // HOLDING voit tout · SUBSIDIARY/FOUNDATION voient uniquement leur entity_id.
    match /finance/{docId} {
      allow read: if isAuthenticated() && canReadOwnEntity(resource.data.entity_id)
                  && (isManager() || hasRole('FINANCE') || hasRole('ACCOUNTING'));
      allow create, update: if isAuthenticated() && canWriteOwnEntity(request.resource.data.entity_id)
                  && (isManager() || hasRole('FINANCE') || hasRole('ACCOUNTING'));
      allow delete: if false;
    }

    match /accounting/{docId} {
      allow read: if isAuthenticated() && canReadOwnEntity(resource.data.entity_id)
                  && (isManager() || hasRole('FINANCE') || hasRole('ACCOUNTING'));
      allow write: if false; // BANK-GRADE: Only Cloud Functions can write to accounting ledger
    }

    match /financial_periods/{docId} {
      allow read: if isAuthenticated() && canReadOwnEntity(resource.data.entity_id)
                  && (isManager() || hasRole('FINANCE') || hasRole('ACCOUNTING'));
      allow write: if false; // Only Cloud Functions / Super Admins manage periods
    }

    match /sales/{docId} {
      allow read: if isAuthenticated() && canReadOwnEntity(resource.data.entity_id)
                  && (isManager() || hasRole('SALES') || hasRole('STAFF') || hasRole('FINANCE'));
      allow create, update: if isAuthenticated() && canWriteOwnEntity(request.resource.data.entity_id)
                  && (isManager() || hasRole('SALES') || hasRole('STAFF'));
      allow delete: if false;
    }

    match /crm/{docId} {
      allow read: if isAuthenticated() && canReadOwnEntity(resource.data.entity_id)
                  && (isManager() || hasRole('SALES') || hasRole('CRM') || hasRole('STAFF'));
      allow create, update: if isAuthenticated() && canWriteOwnEntity(request.resource.data.entity_id)
                  && (isManager() || hasRole('SALES') || hasRole('CRM'));
      allow delete: if false;
    }

    match /inventory/{docId} {
      allow read: if isAuthenticated() && canReadOwnEntity(resource.data.entity_id);
      allow create, update: if isAuthenticated() && canWriteOwnEntity(request.resource.data.entity_id)
                  && (isManager() || hasRole('LOGISTICS') || hasRole('PRODUCTION'));
      allow delete: if false;
    }

    match /production/{docId} {
      allow read: if isAuthenticated() && canReadOwnEntity(resource.data.entity_id);
      allow create, update: if isAuthenticated() && canWriteOwnEntity(request.resource.data.entity_id)
                  && (isManager() || hasRole('PRODUCTION'));
      allow delete: if false;
    }

    match /purchase/{docId} {
      allow read: if isAuthenticated() && canReadOwnEntity(resource.data.entity_id);
      allow create, update: if isAuthenticated() && canWriteOwnEntity(request.resource.data.entity_id)
                  && (isManager() || hasRole('LOGISTICS') || hasRole('PURCHASE'));
      allow delete: if false;
    }

    match /logistics/{docId} {
      allow read: if isAuthenticated() && canReadOwnEntity(resource.data.entity_id);
      allow create, update: if isAuthenticated() && canWriteOwnEntity(request.resource.data.entity_id)
                  && (isManager() || hasRole('LOGISTICS'));
      allow delete: if false;
    }

    match /planning/{docId} {
      allow read: if isAuthenticated() && canReadOwnEntity(resource.data.entity_id);
      allow create, update: if isAuthenticated() && canWriteOwnEntity(request.resource.data.entity_id)
                  && (isManager() || hasRole('HR') || isSuperAdmin());
      allow delete: if isSuperAdmin();
    }

    match /legal/{docId} {
      allow read: if isAuthenticated() && canReadOwnEntity(resource.data.entity_id)
                  && (isManager() || hasRole('LEGAL'));
      allow create, update: if isAuthenticated() && canWriteOwnEntity(request.resource.data.entity_id)
                  && (isManager() || hasRole('LEGAL'));
      allow delete: if false;
    }

    // [3-SPACE ISOLATION] Documents de signature scopés par entité.
    match /signature/{docId} {
      allow read: if isAuthenticated() && canReadOwnEntity(resource.data.entity_id);
      allow create, update: if isAuthenticated() && canWriteOwnEntity(request.resource.data.entity_id);
      allow delete: if isAdmin() && canWriteOwnEntity(resource.data.entity_id);
    }

    match /base/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
      allow delete: if isAdmin();
    }

    // [3-SPACE ISOLATION] Activités scopées par entité.
    match /activities/{docId} {
      allow read: if isAuthenticated() && canReadOwnEntity(resource.data.entity_id);
      allow create: if isAuthenticated() && canWriteOwnEntity(request.resource.data.entity_id);
      allow update: if isAuthenticated() && canWriteOwnEntity(resource.data.entity_id) && (
        resource.data._createdBy == request.auth.uid || isAdmin()
      );
      allow delete: if isAdmin() && canWriteOwnEntity(resource.data.entity_id);
    }

    // [3-SPACE ISOLATION] Campagnes marketing scopées par entité.
    match /marketing/{docId} {
      allow read: if isAuthenticated() && canReadOwnEntity(resource.data.entity_id);
      allow write: if isAuthenticated() && canWriteOwnEntity(request.resource.data.entity_id) &&
                   (isManager() || hasRole('MARKETING'));
      allow delete: if isManager() && canWriteOwnEntity(resource.data.entity_id);
    }

    // ── Audit Trail (lecture seule pour tous, écriture Cloud Functions) ────────
    match /audit_logs/{logId} {
      allow read: if isAuthenticated() && (isAdmin() || hasRole('AUDIT') || hasRole('SECURITY'));
      allow write: if false; // Écrit uniquement par Cloud Functions (admin SDK)
    }

    // ── Audit (collection legacy utilisée par BusinessContext.subscribeToCollection) ──
    // [3-SPACE ISOLATION] Chaque entité ne voit que ses propres audits.
    // HOLDING voit tous les audits (supervision groupe — lecture seule).
    match /audit/{docId} {
      allow read: if isAuthenticated() && canReadOwnEntity(resource.data.entity_id) &&
                  (isManager() || hasRole('AUDIT') || hasRole('SECURITY'));
      allow create, update: if isAuthenticated() && canWriteOwnEntity(request.resource.data.entity_id) && isAdmin();
      allow delete: if isSuperAdmin();
    }

    // ── Cockpit (KPI consolidés alimentés par CF refreshCockpitMetrics) ─────
    // [3-SPACE ISOLATION] Les filiales voient uniquement leurs propres KPI.
    // HOLDING voit les cockpits de TOUTES les entités (vision consolidée — lecture seule).
    match /cockpit/{docId} {
      allow read: if isAuthenticated() && canReadOwnEntity(resource.data.entity_id) && (
        isManager() ||
        hasRole('DIRECTOR') ||
        hasRole('FINANCE') ||
        hasRole('HR_MANAGER')
      );
      allow write: if false; // Cloud Functions only (refreshCockpitMetrics)
    }

    // ── hr_private collection-group queries ────────────────────────────────
    // Sub-collection /users/{uid}/hr_private/{doc} a déjà sa règle ligne 85.
    // collectionGroup('hr_private') nécessite une règle séparée — sinon
    // permission-denied même pour HR_MANAGER.
    // [3-SPACE ISOLATION] HR local ne voit QUE les salaires de sa propre entité.
    // HOLDING_CHRO voit tout (supervision groupe) via isHoldingLevel().
    match /{path=**}/hr_private/{docId} {
      allow read: if isAuthenticated() && (
        isSuperAdmin() ||
        // HOLDING HR voit tous les dossiers du groupe (consolidation RH)
        isHoldingLevel() ||
        // HR local voit uniquement les dossiers de son entité (entity_id dans le doc ou pas encore migré)
        (
          (hasRole('HR_MANAGER') || hasRole('DIRECTOR')) && (
            !('entity_id' in resource.data) ||
            resource.data.entity_id == getEntityId()
          )
        )
      );
      allow write: if false; // Géré par la sub-collection rule ci-dessus
    }

    // ── DMS / Documents ───────────────────────────────────────────────────────
    match /documents/{docId} {
      allow read: if isAuthenticated() && canReadOwnEntity(resource.data.entity_id) && (
        isManager() || hasRole('STAFF') ||
        resource.data.userId == request.auth.uid ||
        ('ownerId' in resource.data && resource.data.ownerId == request.auth.uid)
      );
      allow create, update: if isAuthenticated() && canWriteOwnEntity(request.resource.data.entity_id);
      allow delete: if false;
    }

    // ── Services Généraux / Administration ────────────────────────────────────
    match /mail_logs/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
      allow delete: if isAdmin();
    }
    match /office_supplies/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
      allow delete: if isAdmin();
    }
    match /visitors_log/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
      allow delete: if isAdmin();
    }
    match /facilities_tickets/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
      allow delete: if isAdmin();
    }

    // ── Paramètres Globaux (Hub de Configuration) ──────────────────────────────
    match /settings/{docId} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin(); // Uniquement pour le Super Admin
    }

    // ── Maintenance (GMAO) ──────────────────────────────────────────────────
    match /maintenance/{docId} {
      allow read: if isAuthenticated() && canReadOwnEntity(resource.data.entity_id);
      allow create, update: if isAuthenticated() && canWriteOwnEntity(request.resource.data.entity_id)
                  && (isManager() || hasRole('PRODUCTION') || hasRole('MAINTENANCE'));
      allow delete: if false;
    }

    // ── Paie & Social ──────────────────────────────────────────────────────
    match /payroll/{docId} {
      allow read: if isAuthenticated() && canReadOwnEntity(resource.data.entity_id)
                  && (isManager() || hasRole('HR') || hasRole('FINANCE'));
      allow create, update: if isAuthenticated() && canWriteOwnEntity(request.resource.data.entity_id)
                  && (isManager() || hasRole('HR') || hasRole('FINANCE'));
      allow delete: if false;
    }

    // ── Appels d'Offres (Procurement) ──────────────────────────────────────
    match /procurement/{docId} {
      allow read: if isAuthenticated() && canReadOwnEntity(resource.data.entity_id);
      allow create, update: if isAuthenticated() && canWriteOwnEntity(request.resource.data.entity_id)
                  && (isManager() || hasRole('PURCHASE') || hasRole('FINANCE'));
      allow delete: if false;
    }

    // ── ESG & Environnement ────────────────────────────────────────────────
    match /esg/{docId} {
      allow read: if isAuthenticated() && canReadOwnEntity(resource.data.entity_id);
      allow create, update: if isAuthenticated() && canWriteOwnEntity(request.resource.data.entity_id)
                  && (isManager() || hasRole('PRODUCTION'));
      allow delete: if false;
    }

    // ── Projets ────────────────────────────────────────────────────────────
    match /projects/{docId} {
      allow read: if isAuthenticated() && canReadOwnEntity(resource.data.entity_id)
                  && (isManager() || hasRole('STAFF') || hasRole('PRODUCTION'));
      allow create, update: if isAuthenticated() && canWriteOwnEntity(request.resource.data.entity_id)
                  && (isManager() || hasRole('STAFF'));
      allow delete: if false;
    }

    // ── Budget ─────────────────────────────────────────────────────────────
    match /budget/{docId} {
      allow read: if isAuthenticated() && canReadOwnEntity(resource.data.entity_id)
                  && (isManager() || hasRole('FINANCE'));
      allow create, update: if isAuthenticated() && canWriteOwnEntity(request.resource.data.entity_id)
                  && (isManager() || hasRole('FINANCE'));
      allow delete: if false;
    }

    // ── Internal Infrastructure (Sync & Integrity) ──────────────────────────
    match /sync_queue/{docId} {
      allow read, write: if isSuperAdmin();
    }
    match /processedEvents/{docId} {
      allow read, write: if isSuperAdmin();
    }

    // ── Communication Hub (Mail Integration) ──────────────────────────────────
    match /user_mail_accounts/{userId} {
      allow read, write: if isOwner(userId) || isSuperAdmin();
    }
    match /user_mails/{mailId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isSuperAdmin());
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && (resource.data.userId == request.auth.uid || isSuperAdmin());
      allow delete: if isSuperAdmin();
    }
    match /mail_outbox/{docId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isSuperAdmin());
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSuperAdmin();
    }

    match /talent/{docId} {
      allow read: if isAuthenticated() && canReadOwnEntity(resource.data.entity_id)
                  && (isSuperAdmin() || isManager() || hasRole('HR'));
      allow create, update: if isAuthenticated() && canWriteOwnEntity(request.resource.data.entity_id)
                  && (isSuperAdmin() || isManager() || hasRole('HR'));
      allow delete: if isSuperAdmin();
    }

    match /commerce/{docId} {
      allow read: if isAuthenticated() && canReadOwnEntity(resource.data.entity_id);
      allow create, update: if isAuthenticated() && canWriteOwnEntity(request.resource.data.entity_id)
                  && (isManager() || hasRole('SALES'));
      allow delete: if false;
    }

    match /website/{docId} {
      allow read: if isAuthenticated() && canReadOwnEntity(resource.data.entity_id);
      allow create, update: if isAuthenticated() && canWriteOwnEntity(request.resource.data.entity_id)
                  && (isManager() || hasRole('MARKETING') || hasRole('STAFF'));
      allow delete: if isSuperAdmin();
    }

    // [3-SPACE ISOLATION] Connect Plus scopé par entity_id — Holding/Filiale/Foundation
    // ne voient PAS les conversations des autres espaces.
    match /connect/{docId} {
      allow read: if isAuthenticated() && canReadOwnEntity(resource.data.entity_id);
      allow create, update: if isAuthenticated() && canWriteOwnEntity(request.resource.data.entity_id);
      allow delete: if isSuperAdmin() || isOwner(resource.data.userId);
    }

    // [3-SPACE ISOLATION] Le GED (DMS) est strictement scopé par entité.
    // Un manager filiale ne doit JAMAIS voir les documents DMS d'une autre filiale.
    match /dms/{docId} {
      allow read: if isAuthenticated() && canReadOwnEntity(resource.data.entity_id) &&
                  (isSuperAdmin() || isManager() || hasRole('STAFF') || resource.data.ownerId == request.auth.uid);
      allow create, update: if isAuthenticated() && canWriteOwnEntity(request.resource.data.entity_id);
      allow delete: if isSuperAdmin();
    }

    // ── Missions RBAC helpers ────────────────────────────────────────────────
    //
    // Workspace membership is stored as a Firestore map:
    //   memberRoles: { uid1: 'ADMIN', uid2: 'MEMBER', uid3: 'VIEWER' }
    //
    // This allows an O(1) key-lookup in rules without array iteration.
    // All missions sub-resources inherit access from their parent workspace.

    function missionsWsRef(wsId) {
      return /databases/$(database)/documents/missions_workspaces/$(wsId);
    }

    function isMissionsWsMember(wsId) {
      return isSuperAdmin() ||
             (isAuthenticated() &&
              request.auth.uid in get(missionsWsRef(wsId)).data.memberRoles);
    }

    function missionsWsRole(wsId) {
      return get(missionsWsRef(wsId)).data.memberRoles.get(request.auth.uid, 'NONE');
    }

    function canWriteMissions(wsId) {
      return isMissionsWsMember(wsId) && missionsWsRole(wsId) != 'VIEWER';
    }

    function isMissionsWsAdmin(wsId) {
      return isSuperAdmin() || missionsWsRole(wsId) == 'ADMIN';
    }

    // ── Missions (Kanban ERP) ────────────────────────────────────────────────

    match /missions_workspaces/{wsId} {
      // Any authenticated user can see the workspace list (workspace picker UI)
      allow read: if isAuthenticated() &&
                     (isSuperAdmin() ||
                      request.auth.uid in resource.data.memberRoles);
      // Any authenticated user can create a new workspace
      allow create: if isAuthenticated();
      // Only ADMIN members can update workspace metadata
      allow update: if isAuthenticated() &&
                       (isSuperAdmin() ||
                        resource.data.memberRoles.get(request.auth.uid, 'NONE') == 'ADMIN');
      allow delete: if isSuperAdmin();
    }

    match /missions_boards/{boardId} {
      allow read:   if isMissionsWsMember(resource.data.workspaceId);
      allow create: if canWriteMissions(request.resource.data.workspaceId);
      allow update: if canWriteMissions(resource.data.workspaceId);
      allow delete: if isMissionsWsAdmin(resource.data.workspaceId);

      match /butler_rules/{ruleId} {
        // Board workspaceId must be fetched from the parent board doc
        allow read:  if isMissionsWsMember(
                          get(/databases/$(database)/documents/missions_boards/$(boardId)).data.workspaceId);
        allow write: if isMissionsWsAdmin(
                          get(/databases/$(database)/documents/missions_boards/$(boardId)).data.workspaceId);
      }
    }

    match /missions_lists/{listId} {
      allow read:   if isMissionsWsMember(resource.data.workspaceId);
      allow create: if canWriteMissions(request.resource.data.workspaceId);
      allow update: if canWriteMissions(resource.data.workspaceId);
      allow delete: if isMissionsWsAdmin(resource.data.workspaceId);
    }

    match /missions_cards/{cardId} {
      allow read:   if isMissionsWsMember(resource.data.workspaceId);
      allow create: if canWriteMissions(request.resource.data.workspaceId);
      allow update: if canWriteMissions(resource.data.workspaceId);
      allow delete: if isMissionsWsAdmin(resource.data.workspaceId);

      match /activity/{actId} {
        // Read: workspace members only. Write: Cloud Functions Admin SDK only.
        allow read:  if isMissionsWsMember(
                          get(/databases/$(database)/documents/missions_cards/$(cardId)).data.workspaceId);
        allow write: if false;
      }

      match /comments/{commentId} {
        allow read:   if isMissionsWsMember(
                           get(/databases/$(database)/documents/missions_cards/$(cardId)).data.workspaceId);
        allow create: if isAuthenticated() &&
                         canWriteMissions(
                           get(/databases/$(database)/documents/missions_cards/$(cardId)).data.workspaceId) &&
                         request.resource.data.authorUid == request.auth.uid;
        allow update, delete: if isAuthenticated() &&
                                  (resource.data.authorUid == request.auth.uid || isSuperAdmin());
      }

      match /checklists/{clId} {
        allow read:        if isMissionsWsMember(
                                get(/databases/$(database)/documents/missions_cards/$(cardId)).data.workspaceId);
        allow create, update: if canWriteMissions(
                                    get(/databases/$(database)/documents/missions_cards/$(cardId)).data.workspaceId);
        allow delete:      if isMissionsWsAdmin(
                                get(/databases/$(database)/documents/missions_cards/$(cardId)).data.workspaceId);
      }

      match /attachments/{attId} {
        allow read:   if isMissionsWsMember(
                           get(/databases/$(database)/documents/missions_cards/$(cardId)).data.workspaceId);
        allow create: if canWriteMissions(
                           get(/databases/$(database)/documents/missions_cards/$(cardId)).data.workspaceId);
        allow delete: if isAuthenticated() &&
                         (resource.data.uploadedBy == request.auth.uid || isSuperAdmin());
      }
    }

    match /missions_reports/{boardId} {
      allow read:  if isAuthenticated() && (isManager() || isSuperAdmin());
      allow write: if false; // Cloud Functions only (Admin SDK)
    }

    // ── Audit Logs (Immuable) ────────────────────────────────────────────────
    // [3-SPACE ISOLATION] Chaque entité ne voit que ses propres logs d'audit.
    // HOLDING voit tous les logs (surveillance groupe).
    match /audit_logs/{logId} {
      allow read: if isAuthenticated() && canReadOwnEntity(resource.data.entity_id) &&
                  (isSuperAdmin() || isManager() || hasRole('SECURITY') || hasRole('AUDIT'));
      allow write: if false; // Uniquement via Cloud Functions (Admin SDK)
    }

    match /financial_audit_logs/{logId} {
      allow read: if isAuthenticated() && (isSuperAdmin() || hasRole('AUDIT') || hasRole('CFO'));
      allow write: if false; // BANK-GRADE: Only Cloud Functions can write to financial audit logs
    }

    match /counters/{docId} {
      allow read: if isAuthenticated() && (isSuperAdmin() || hasRole('FINANCE'));
      allow write: if false; // Only Cloud Functions can update counters
    }

    // ══════════════════════════════════════════════════════════════════
    // GROUP GOVERNANCE — 3-Level Org Architecture
    // HOLDING > SUBSIDIARIES > FOUNDATION
    // ══════════════════════════════════════════════════════════════════

    // ── Helper: entity type from Custom Claims ────────────────────────────
    function getEntityType() {
      return isAuthenticated() ? request.auth.token.get('entity_type', '') : '';
    }

    function getEntityId() {
      return isAuthenticated() ? request.auth.token.get('entity_id', '') : '';
    }

    // v3.0 — Country governance: country_id from Custom Claims
    function getCountryId() {
      return isAuthenticated() ? request.auth.token.get('country_id', '') : '';
    }

    // True if user is a country-scoped role (COUNTRY_DIRECTOR_*, COUNTRY_HR…)
    function isCountryLevel() {
      return isAuthenticated() && (
        hasClaimRole('COUNTRY_DIRECTOR_SUBSIDIARY') ||
        hasClaimRole('COUNTRY_DIRECTOR_FOUNDATION') ||
        hasClaimRole('COUNTRY_HR')         ||
        hasClaimRole('COUNTRY_FINANCE')    ||
        hasClaimRole('COUNTRY_OPERATIONS') ||
        hasClaimRole('COUNTRY_AUDITOR')
      );
    }

    // True iff the resource shares the user's country (or no country filter applies)
    function sameCountry(docCountryId) {
      return getCountryId() == docCountryId;
    }

    // ── [3-SPACE ISOLATION] Helper: tenant-aware read access ───────────────
    // HOLDING : voit tout (consolidation stratégique — lecture uniquement)
    // Sinon  : voit uniquement les docs de SON entity_id
    // Si le doc n'a pas d'entity_id (collections globales pré-existantes),
    // autorisation accordée pour compat — à durcir au cas par cas.
    function canReadOwnEntity(docEntityId) {
      return isHoldingLevel() ||
             docEntityId == null ||
             docEntityId == '' ||
             docEntityId == getEntityId();
    }

    // ── [3-SPACE ISOLATION] Helper: tenant-aware WRITE access ──────────────
    // CRITIQUE : PAS DE BYPASS HOLDING — la Holding ne peut écrire QUE ses propres docs.
    // La Holding supervise en LECTURE (canReadOwnEntity), mais ne modifie JAMAIS
    // les données opérationnelles locales (filiales/foundations).
    //
    // Règle : entity_id du doc doit correspondre à entity_id du caller.
    //         Exception : SUPER_ADMIN (opérations d'urgence) et docs sans entity_id (legacy).
    function canWriteOwnEntity(docEntityId) {
      return isSuperAdmin() ||
             docEntityId == null ||
             docEntityId == '' ||
             docEntityId == getEntityId();
    }

    // Bonus : isolation country pour les rôles COUNTRY_* (filtre + strict)
    function canReadOwnCountry(docCountryId) {
      return isHoldingLevel() ||
             docCountryId == null ||
             docCountryId == '' ||
             docCountryId == getCountryId();
    }

    // Holding roles: full group visibility
    function isHoldingLevel() {
      return isAuthenticated() && (
        isSuperAdmin() ||
        hasClaimRole('HOLDING_CEO')    || hasRole('HOLDING_CEO')    ||
        hasClaimRole('HOLDING_CFO')    || hasRole('HOLDING_CFO')    ||
        hasClaimRole('HOLDING_CSO')    || hasRole('HOLDING_CSO')    ||
        hasClaimRole('HOLDING_CHRO')   || hasRole('HOLDING_CHRO')   ||
        hasClaimRole('HOLDING_CTO')    || hasRole('HOLDING_CTO')    ||
        hasClaimRole('HOLDING_AUDITOR')|| hasRole('HOLDING_AUDITOR')||
        hasClaimRole('HOLDING_LEGAL')  || hasRole('HOLDING_LEGAL')  ||
        hasClaimRole('GROUP_AUDITOR')  || hasRole('GROUP_AUDITOR')
      );
    }

    // Subsidiary roles: scoped to their entity_id
    function isSubsidiaryLevel() {
      return isAuthenticated() && (
        hasClaimRole('SUBSIDIARY_DG')      || hasRole('SUBSIDIARY_DG')      ||
        hasClaimRole('SUBSIDIARY_CFO')     || hasRole('SUBSIDIARY_CFO')     ||
        hasClaimRole('SUBSIDIARY_RH')      || hasRole('SUBSIDIARY_RH')      ||
        hasClaimRole('SUBSIDIARY_MANAGER') || hasRole('SUBSIDIARY_MANAGER') ||
        hasClaimRole('SUBSIDIARY_STAFF')   || hasRole('SUBSIDIARY_STAFF')   ||
        isAdmin() // legacy
      );
    }

    // Foundation roles: scoped to Foundation entities only
    function isFoundationLevel() {
      return isAuthenticated() && (
        isSuperAdmin() ||
        hasClaimRole('FOUNDATION_DG')      || hasRole('FOUNDATION_DG')      ||
        hasClaimRole('FOUNDATION_MANAGER') || hasRole('FOUNDATION_MANAGER') ||
        hasClaimRole('FOUNDATION_STAFF')   || hasRole('FOUNDATION_STAFF')   ||
        hasClaimRole('FOUNDATION_AUDITOR') || hasRole('FOUNDATION_AUDITOR')
      );
    }

    function isFoundationAdmin() {
      return isAuthenticated() && (
        isSuperAdmin() ||
        hasClaimRole('FOUNDATION_DG') || hasRole('FOUNDATION_DG') ||
        isHoldingLevel()
      );
    }

    // Entity scoping: a subsidiary user can only see docs for their entity
    function canAccessEntityDoc(docEntityId) {
      return isHoldingLevel() ||
             isFoundationLevel() ||
             getEntityId() == docEntityId ||
             !('entity_id' in resource.data); // unscoped doc = visible to all authenticated
    }

    // ── Organizations Registry (Holding-managed) ──────────────────────────
    match /organizations/{orgId} {
      // Holding sees all; country-scoped users see entities of their country;
      // subsidiaries see their own + parent holding
      allow read: if isAuthenticated() && (
        isHoldingLevel() ||
        resource.data.id == getEntityId() ||
        resource.data.parentId == getEntityId() ||
        // v3.0 — country governance: country-scoped users see same-country entities
        (isCountryLevel() && resource.data.country_id == getCountryId())
      );
      allow create, update: if isHoldingLevel();
      allow delete: if isSuperAdmin();
    }

    // ── Country Scopes (v3.0 — Holding governance) ────────────────────────
    // collection top-level créée par provisionCountryScope (CF).
    // - Holding voit tous les pays
    // - Country-scoped users voient UNIQUEMENT leur country_id
    // - Aucune écriture client → Cloud Functions exclusivement
    match /country_scopes/{countryId} {
      allow read: if isAuthenticated() && (
        isHoldingLevel() ||
        countryId == getCountryId()
      );
      allow write: if false; // Cloud Functions only (provisionCountryScope)
    }

    // ── Consolidated Reports (Holding-only) ───────────────────────────────
    match /consolidated_reports/{reportId} {
      allow read: if isAuthenticated() && (
        isHoldingLevel() || hasRole('GROUP_AUDITOR')
      );
      allow write: if false; // Written by Cloud Functions only
    }

    // ── Intercompany Transactions & Approvals ─────────────────────────────
    match /intercompany/{txId} {
      allow read: if isAuthenticated() && (
        isHoldingLevel() ||
        resource.data.fromEntityId == getEntityId() ||
        resource.data.toEntityId   == getEntityId()
      );
      allow create: if isAuthenticated() && (isManager() || isSubsidiaryLevel());
      allow update: if isAuthenticated() && (
        isHoldingLevel() || // Holding approves
        (resource.data.fromEntityId == getEntityId() && resource.data.status == 'draft')
      );
      allow delete: if false;
    }

    match /intercompany_approvals/{docId} {
      allow read: if isAuthenticated() && (isHoldingLevel() || isManager());
      allow create: if isAuthenticated() && isManager();
      allow update: if isAuthenticated() && isHoldingLevel(); // Only Holding approves
      allow delete: if false;
    }

    // ── Group Budgets (Consolidated + Per-entity) ─────────────────────────
    match /group_budgets/{docId} {
      allow read: if isAuthenticated() && (
        isHoldingLevel() ||
        resource.data.entity_id == getEntityId()
      );
      allow create, update: if isAuthenticated() && (
        isHoldingLevel() ||
        (isManager() && resource.data.entity_id == getEntityId())
      );
      allow delete: if false;
    }

    // ── ESG Consolidated (Holding reads all; entities write their own) ─────
    match /esg_consolidated/{docId} {
      allow read: if isAuthenticated() && (isHoldingLevel() || isFoundationLevel() || isManager());
      allow write: if false; // Cloud Functions aggregate from /esg per entity
    }

    // ══════════════════════════════════════════════════════════════════
    // FOUNDATION — IPC Foundation (Non-Profit Entity)
    // Supervised by Holding; isolated from commercial subsidiaries
    // ══════════════════════════════════════════════════════════════════

    // ── Foundation Donations ──────────────────────────────────────────────
    match /foundation_donations/{docId} {
      allow read: if isFoundationLevel() || isHoldingLevel();
      allow create: if isFoundationLevel();
      allow update: if isFoundationLevel() && (
        isFoundationAdmin() ||
        !request.resource.data.diff(resource.data).affectedKeys().hasAny([
          'statut', 'approuve_par', 'approuve_le', 'validation'
        ])
      );
      allow delete: if false; // Financial immutability
    }

    // ── Foundation Programs ───────────────────────────────────────────────
    match /foundation_programs/{docId} {
      allow read: if isFoundationLevel() || isHoldingLevel();
      allow create, update: if isFoundationLevel();
      allow delete: if false;
    }

    // ── Foundation Beneficiaries ──────────────────────────────────────────
    match /foundation_beneficiaries/{docId} {
      allow read: if isFoundationLevel() || isHoldingLevel();
      allow create, update: if isFoundationLevel();
      allow delete: if false; // Personal data — soft delete only
    }

    // ── Foundation Campaigns ──────────────────────────────────────────────
    match /foundation_campaigns/{docId} {
      allow read: if isAuthenticated(); // Public visibility for campaigns
      allow create, update: if isFoundationLevel();
      allow delete: if isFoundationAdmin();
    }

    // ── Foundation Finance (Budgets, Disbursements) ───────────────────────
    match /foundation_finance/{docId} {
      allow read: if isFoundationLevel() || isHoldingLevel();
      allow create: if isFoundationLevel();
      allow update: if isFoundationLevel() && (
        isFoundationAdmin() ||
        !request.resource.data.diff(resource.data).affectedKeys().hasAny([
          'statut', 'approuve_par', 'approuve_le', 'commentaire_validation'
        ])
      );
      allow delete: if false;
    }

    // ── Foundation Partners ───────────────────────────────────────────────
    match /foundation_partners/{docId} {
      allow read: if isFoundationLevel() || isHoldingLevel();
      allow create, update: if isFoundationLevel();
      allow delete: if isFoundationAdmin();
    }

    // ── Foundation ESG Reports ────────────────────────────────────────────
    match /foundation_esg_reports/{docId} {
      allow read: if isFoundationLevel() || isHoldingLevel();
      allow create, update: if isFoundationLevel();
      allow delete: if false; // Immutable ESG audit trail
    }

    // ── Foundation Governance (Board decisions, minutes) ──────────────────
    match /foundation_governance/{docId} {
      allow read: if isFoundationLevel() || isHoldingLevel();
      allow create, update: if isFoundationAdmin();
      allow delete: if false;
    }

    // ══════════════════════════════════════════════════════════════════
    // HOLDING SaaS LICENSING — Entity Licenses, Usage & Upgrade Requests
    // ══════════════════════════════════════════════════════════════════

    // ── Entity Licenses (plan assignments per entity) ─────────────────────
    // Holding: full CRUD. Entities: read their own license only.
    // Writes always go through Cloud Functions (assignEntityLicense callable).
    match /entity_licenses/{entityId} {
      allow read: if isAuthenticated() && (
        isHoldingLevel() ||
        getEntityId() == entityId
      );
      allow write: if false; // Cloud Functions only (assignEntityLicense, createGroupEntity)
    }

    // ── Entity Usage Metrics ──────────────────────────────────────────────
    // Counters updated by Cloud Functions on write triggers.
    match /entity_usage/{entityId} {
      allow read: if isAuthenticated() && (
        isHoldingLevel() ||
        getEntityId() == entityId
      );
      allow write: if false; // Cloud Functions only
    }

    // ── Upgrade Requests (subsidiary → Holding approval queue) ────────────
    match /upgrade_requests/{reqId} {
      // Subsidiaries: create and read their own requests.
      // Holding: read all and approve/reject.
      allow read: if isAuthenticated() && (
        isHoldingLevel() ||
        resource.data.entity_id == getEntityId()
      );
      allow create: if isAuthenticated() && (
        isSubsidiaryLevel() || isFoundationLevel()
      ) && request.resource.data.entity_id == getEntityId();
      allow update: if isAuthenticated() && isHoldingLevel(); // approval path
      allow delete: if isSuperAdmin();
    }

    // ── Organization Structure (departments per entity) ───────────────────
    match /organization_structure/{entityId} {
      allow read: if isAuthenticated() && (
        isHoldingLevel() ||
        getEntityId() == entityId
      );
      allow create: if false; // Cloud Functions only (createGroupEntity)
      allow update: if isAuthenticated() && (
        isHoldingLevel() ||
        (getEntityId() == entityId && (isManager() || isSubsidiaryLevel()))
      );
      allow delete: if isSuperAdmin();
    }

    // ── Refus par défaut (sécurité) ────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
