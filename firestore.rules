rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ── SECURITY FUNCTIONS ───────────────────────────────────────────────────
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isSuperAdmin() {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             getUserDoc().permissions.roles.hasAny(['SUPER_ADMIN']);
    }
    
    function hasAnyRole(roles) {
      return isSuperAdmin() || (
        isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        getUserDoc().permissions.roles.hasAny(roles)
      );
    }

    // Helper to check ownership
    function isOwner(docData) {
      return docData.ownerId == request.auth.uid || docData._createdBy == request.auth.uid;
    }

    // ── USERS ────────────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isSuperAdmin() || hasAnyRole(['ADMIN', 'HR']);
      allow delete: if isSuperAdmin();
      allow update: if isSuperAdmin() 
                    || hasAnyRole(['ADMIN', 'HR'])
                    || (isAuthenticated() && request.auth.uid == userId && 
                        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['permissions']));
    }

    // ── FINANCE ──────────────────────────────────────────────────────────────
    // Covers finance_invoices, finance_accounting, finance_treasury
    match /{col}/{docId} {
      allow read: if col.startsWith('finance_') && hasAnyRole(['FINANCE', 'ADMIN', 'MANAGER']);
      // Writing to finance is restricted to specialists, except invoices which Sales can create
      allow create: if col == 'finance_invoices' && hasAnyRole(['SALES', 'FINANCE', 'ADMIN']);
      allow update: if col == 'finance_invoices' && (hasAnyRole(['FINANCE', 'ADMIN']) || (hasAnyRole(['SALES']) && isOwner(resource.data)));
      allow write: if col.startsWith('finance_') && hasAnyRole(['FINANCE', 'ADMIN']);
    }

    // ── INVENTORY & PRODUCTION ──────────────────────────────────────────────
    match /{col}/{docId} {
      allow read: if (col.startsWith('inventory_') || col.startsWith('production_')) && isAuthenticated();
      allow write: if (col.startsWith('inventory_') || col.startsWith('production_')) && 
                   hasAnyRole(['STOCK_MANAGER', 'PRODUCTION_MANAGER', 'ADMIN', 'MANAGER']);
    }

    // ── CRM & SALES ──────────────────────────────────────────────────────────
    match /{col}/{docId} {
      allow read: if (col.startsWith('crm_') || col.startsWith('sales_')) && hasAnyRole(['SALES', 'MARKETING', 'ADMIN', 'MANAGER']);
      allow write: if (col.startsWith('crm_') || col.startsWith('sales_')) && hasAnyRole(['SALES', 'MARKETING', 'ADMIN', 'MANAGER']);
    }

    // ── HR ─────────────────────────────────────────────────────────────────
    match /hr_{sub}/{docId} {
      allow read: if hasAnyRole(['HR', 'ADMIN', 'MANAGER']);
      allow write: if hasAnyRole(['HR', 'ADMIN']);
    }

    // ── SYSTEM & AUDIT (Admin Only) ─────────────────────────────────────────
    match /audit_logs/{docId} {
      allow read: if hasAnyRole(['ADMIN', 'FINANCE']);
      allow write: if false; // Only Cloud Functions can write
    }

    match /system_config/{docId} { 
      allow read: if isAuthenticated(); // Some config needed for UI
      allow write: if isSuperAdmin(); 
    }

    match /system_incidents/{docId} {
      allow read: if hasAnyRole(['ADMIN']);
      allow create: if isAuthenticated(); 
      allow update, delete: if false;
    }

    // ── REAL-TIME COMMS ──────────────────────────────────────────────────────
    match /rooms/{roomId} {
      allow read: if isAuthenticated();
      
      match /participants/{userId} {
        allow read: if isAuthenticated();
        allow create, update: if request.auth.uid == userId;
        allow delete: if request.auth.uid == userId || isSuperAdmin();
      }

      match /signals/{signalId} {
        // Can only read signals targeted to me
        allow read: if isAuthenticated() && resource.data.targetId == request.auth.uid;
        // Can only create signals if I am a participant in the room
        allow create: if isAuthenticated() && 
                      request.resource.data.senderId == request.auth.uid &&
                      exists(/databases/$(database)/documents/rooms/$(roomId)/participants/$(request.auth.uid));
        // Only target can delete (after processing)
        allow delete: if isAuthenticated() && resource.data.targetId == request.auth.uid;
      }

      match /messages/{msgId} { 
        allow read: if isAuthenticated();
        allow create: if isAuthenticated() && request.resource.data.senderId == request.auth.uid;
        allow update, delete: if isAuthenticated() && resource.data.senderId == request.auth.uid;
      }
    }

    match /calls/{callId} {
      allow read: if isAuthenticated() && (resource.data.callerId == request.auth.uid || resource.data.receiverId == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.callerId == request.auth.uid;
      allow update: if isAuthenticated() && (resource.data.callerId == request.auth.uid || resource.data.receiverId == request.auth.uid);
      allow delete: if isSuperAdmin();
    }

    // ── FALLBACK (DENY ALL) ──────────────────────────────────────────────────
    // All other collections are denied by default if not explicitly matched above.
    // This is the core of reinforcement.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
