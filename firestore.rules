rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isSuperAdmin() {
      return isAuthenticated() && (
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.permissions.roles.hasAny(['SUPER_ADMIN'])
      );
    }
    
    function hasRole(role) {
      return isSuperAdmin() || (
        isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.permissions.roles.hasAny([role])
      );
    }

    function hasAnyRole(roles) {
      return isSuperAdmin() || (
        isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.permissions.roles.hasAny(roles)
      );
    }
    
    // ── Users ────────────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isSuperAdmin() || hasAnyRole(['ADMIN', 'HR']));
      allow write: if isAuthenticated() && (isSuperAdmin() || hasAnyRole(['ADMIN', 'HR']));
      // Users can only update their own profile, not permissions
      allow update: if isAuthenticated() && request.auth.uid == userId && 
                    !request.resource.data.diff(resource.data).affectedKeys().hasAny(['permissions']);
    }
    
    // ── System Config ────────────────────────────────────────────────────────
    match /system_config/{docId} {
      allow read, write: if isSuperAdmin();
    }

    // ── WebRTC Calls ─────────────────────────────────────────────────────────
    match /calls/{callId} {
      // Access only if part of the call (sender or receiver)
      allow read, write: if isAuthenticated() && (
        resource == null || 
        resource.data.participants.hasAny([request.auth.uid]) ||
        request.resource.data.participants.hasAny([request.auth.uid])
      );
      match /offerCandidates/{candId} {
        allow read, write: if isAuthenticated();
      }
      match /answerCandidates/{candId} {
        allow read, write: if isAuthenticated();
      }
    }

    // ── Rooms (Chat Groups & WebRTC Mesh) ────────────────────────────────────
    match /rooms/{roomId} {
      allow read, write: if isAuthenticated() && (
        resource == null || 
        resource.data.members.hasAny([request.auth.uid]) ||
        isSuperAdmin()
      );
      match /participants/{participantId} {
        allow read, write: if isAuthenticated() && (participantId == request.auth.uid || isSuperAdmin());
      }
      match /signals/{signalId} {
        allow read, write: if isAuthenticated();
      }
    }

    // ── Audit Logs (Strict Write-Only) ───────────────────────────────────────
    match /audit_logs/{docId} {
      allow read: if isSuperAdmin() || hasAnyRole(['ADMIN', 'FINANCE']);
      // Prevent manual deletion or modification of audit trails
      allow create: if isAuthenticated();
      allow update, delete: if false; 
    }

    // ── HR ───────────────────────────────────────────────────────────────────
    match /hr/{docId} {
      allow read, write: if hasAnyRole(['SUPER_ADMIN', 'ADMIN', 'HR']);
    }

    // ── Finance & Accounting ─────────────────────────────────────────────────
    match /finance/{docId} {
      allow read, write: if hasAnyRole(['SUPER_ADMIN', 'ADMIN', 'FINANCE']);
    }
    match /accounting/{docId} {
      allow read, write: if hasAnyRole(['SUPER_ADMIN', 'ADMIN', 'FINANCE']);
    }

    // ── Production ───────────────────────────────────────────────────────────
    match /production/{docId} {
      allow read, write: if hasAnyRole(['SUPER_ADMIN', 'ADMIN', 'PRODUCTION']);
    }

    // ── Inventory / Stock ────────────────────────────────────────────────────
    match /inventory/{docId} {
      allow read: if isAuthenticated();
      allow write: if hasAnyRole(['SUPER_ADMIN', 'ADMIN', 'PRODUCTION', 'LOGISTICS']);
    }

    // ── Purchases ────────────────────────────────────────────────────────────
    match /purchase/{docId} {
      allow read, write: if hasAnyRole(['SUPER_ADMIN', 'ADMIN', 'FINANCE', 'LOGISTICS']);
    }

    // ── CRM & Sales ──────────────────────────────────────────────────────────
    match /crm/{docId} {
      allow read, write: if hasAnyRole(['SUPER_ADMIN', 'ADMIN', 'SALES']);
    }
    match /sales/{docId} {
      allow read, write: if hasAnyRole(['SUPER_ADMIN', 'ADMIN', 'SALES', 'FINANCE']);
    }

    // ── Projects & Marketing ─────────────────────────────────────────────────
    match /projects/{docId} {
      // Projects should only be visible to staff
      allow read, write: if hasAnyRole(['SUPER_ADMIN', 'ADMIN', 'STAFF']);
    }
    match /marketing/{docId} {
      allow read, write: if hasAnyRole(['SUPER_ADMIN', 'ADMIN', 'SALES', 'MARKETING']);
    }

    // ── DMS (G.E.D) ──────────────────────────────────────────────────────────
    match /dms/{docId} {
      allow read: if isAuthenticated();
      allow write: if hasAnyRole(['SUPER_ADMIN', 'ADMIN', 'HR', 'FINANCE', 'DMS_MANAGER']);
    }

    // ── Shared / Base ────────────────────────────────────────────────────────
    match /base/{docId} {
      allow read: if isAuthenticated();
      allow write: if hasAnyRole(['SUPER_ADMIN', 'ADMIN']);
    }
    match /messages/{docId} {
      // Private messaging security
      allow read, write: if isAuthenticated() && (
        resource == null || 
        resource.data.participants.hasAny([request.auth.uid]) ||
        request.resource.data.participants.hasAny([request.auth.uid])
      );
    }
    match /workflows/{docId} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin();
    }
    match /notifications/{docId} {
      // Notifications belong to specific users or roles
      allow read, write: if isAuthenticated() && (
        resource == null || 
        resource.data.targetUserId == request.auth.uid ||
        resource.data.targetRole == null || 
        isSuperAdmin()
      );
    }
  }
}
