# ══════════════════════════════════════════════════════════════════════════════
# IPC ERP — CONFIGURATION DES VARIABLES D'ENVIRONNEMENT
# ══════════════════════════════════════════════════════════════════════════════

# ── FIREBASE CLIENT CONFIG ───────────────────────────────────────────────────
VITE_FIREBASE_API_KEY=your_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id

# ── PUSH NOTIFICATIONS (FCM) ─────────────────────────────────────────────────
# Générée dans Console Firebase -> Paramètres du projet -> Cloud Messaging -> Web Configuration
VITE_FCM_VAPID_KEY=your_vapid_public_key

# ── SÉCURITÉ DU STORE (ZUSTAND) ──────────────────────────────────────────────
# Utilisée pour chiffrer le localStorage. Si absente, une clé par session est générée.
VITE_STORE_KEY=ipc_erp_secure_ultra_secret_key_2026

# ── WEBRTC (STUN/TURN) ───────────────────────────────────────────────────────
# Requis pour les appels vidéo derrière des pare-feux d'entreprise / NAT strict.
# Service recommandé : Metered.ca ou Twilio.
VITE_TURN_URL=turn:your-turn-server.com:3478
VITE_TURN_USERNAME=your_username
VITE_TURN_CREDENTIAL=your_password

# ── AXELOR SSOT (BACKEND ONLY) ───────────────────────────────────────────────
AXELOR_API_URL=https://votre-instance-axelor.com
AXELOR_USERNAME=admin
AXELOR_PASSWORD=admin

# ── NEXUS AI (BACKEND ONLY) ──────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-key
