[debug] [2026-04-14T12:36:43.391Z] <<< [apiv2][body] POST https://firebaserules.googleapis.com/v1/projects/ipc-erp/rulesets {"name":"projects/ipc-erp/rulesets/deb0241e-7bd8-43c7-8f10-69141fbae12b","source":{"files":[{"content":"rules_version = '2';\nservice cloud.firestore {\n  match /databases/{database}/documents {\n    \n    function hasRole(role) {\n      return request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.permissions.roles.hasAny([role]);\n    }\n    \n    match /users/{userId} {\n      allow read, write: if request.auth != null && (\n        request.auth.uid == userId || \n        request.auth.token.email == 'ra.yoman@ipcgreenblocks.com'\n      );\n      allow read, write: if request.auth != null && \n        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.permissions.roles.hasAny(['SUPER_ADMIN']);\n    }\n    \n    match /system_config/{docId} {\n      allow read, write: if request.auth != null && \n        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.permissions.roles.hasAny(['SUPER_ADMIN']);\n    }\n    \n    match /calls/{callId} {\n      allow read, write: if request.auth != null;\n      match /offerCandidates/{candId} {\n        allow read, write: if request.auth != null;\n      }\n      match /answerCandidates/{candId} {\n        allow read, write: if request.auth != null;\n      }\n    }\n\n    match /{collectionName}/{docId} {\n      allow read, write: if request.auth != null && (\n        collectionName == 'crm' || \n        collectionName == 'sales' || \n        collectionName == 'inventory' || \n        collectionName == 'accounting' || \n        collectionName == 'projects' || \n        collectionName == 'audit_logs' || \n        collectionName == 'messages' ||\n        collectionName == 'base' ||\n        collectionName == 'workflows' ||\n        collectionName == 'hr'\n      );\n    }\n  }\n}\n","name":"firestore.rules"}]},"createTime":"2026-04-14T12:36:43.301919Z","metadata":{"services":["cloud.firestore"]}}
